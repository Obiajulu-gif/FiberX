# FiberX proxy configuration
# Copy to .env and adjust as needed.

# Port the proxy server listens on
PORT=3099

# Real Fiber Network Node JSON-RPC URL (only used when FIBER_PROXY_MODE=real)
FIBER_RPC_URL=http://127.0.0.1:8227

# Shared secret required in the `x-fiber-connect-key` header for all /api/* endpoints
FIBER_PROXY_API_KEY=dev-secret

# "mock" runs a fully in-memory Fiber node (no real node required).
# "real" forwards allowed calls to FIBER_RPC_URL.
FIBER_PROXY_MODE=mock

# Allowed browser origin for CORS
CORS_ORIGIN=http://localhost:5173

# Fastify log level (fatal|error|warn|info|debug|trace|silent)
LOG_LEVEL=info

# --- Demo app (Vite) ---
# URL of the proxy the demo talks to for "Proxy Wallet" mode
VITE_PROXY_URL=http://localhost:3099
VITE_PROXY_API_KEY=dev-secret
