# FiberX proxy real-mode configuration
# Copy to apps/proxy/.env on the machine that can reach your Fiber Network Node.

NODE_ENV=production
PORT=3099
LOG_LEVEL=info

# real = forward allowed SDK/proxy operations to a real Fiber Network Node
FIBER_PROXY_MODE=real

# Keep this local/private. Do not expose your Fiber node JSON-RPC port directly
# to the public internet. The proxy should be the public API boundary.
FIBER_RPC_URL=http://127.0.0.1:8227

# Generate a strong value:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
FIBER_PROXY_API_KEY=replace-with-a-generated-secret

# The hosted UI origin allowed to call this proxy.
# For Vercel production use: https://fiber-x-demo.vercel.app
CORS_ORIGIN=https://fiber-x-demo.vercel.app
